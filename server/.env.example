# ──────────────────────────────────────────────────────────────
# Loomic Server – Environment Variables Template
# Copy this file to .env and fill in your real values.
# .env is git-ignored; this file is safe to commit.
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
# libpqxx connection string used by the server
# For Neon, prefer the pooled endpoint (`-pooler`) for application traffic and
# enable libpq keepalives so dead sockets are detected promptly.
LOOMIC_PG_CONN_STRING=host=<project>-pooler.<region>.aws.neon.tech port=5432 dbname=<dbname> user=<user> password=<password> sslmode=require connect_timeout=5 keepalives=1 keepalives_idle=30 keepalives_interval=10 keepalives_count=3

# ── Auth ───────────────────────────────────────────────────────
LOOMIC_JWT_SECRET=<long-random-secret>

# ── Network ────────────────────────────────────────────────────
LOOMIC_BIND_ADDRESS=0.0.0.0
LOOMIC_PORT=9000
LOOMIC_HTTP_HEALTH_PORT=8080
LOOMIC_THREAD_COUNT=0

# ── TLS ────────────────────────────────────────────────────────
LOOMIC_TLS_CERT_PATH=certs/server.crt
LOOMIC_TLS_KEY_PATH=certs/server.key

# ── Redis Cloud ────────────────────────────────────────────────
LOOMIC_REDIS_HOST=<host>.redis.cloud
LOOMIC_REDIS_PORT=6379
LOOMIC_REDIS_PASSWORD=<password>
LOOMIC_REDIS_SSL=true               # set true for Redis Cloud (rediss://)

# ── Azure Cosmos for Apache Cassandra ──────────────────────────
LOOMIC_CASSANDRA_CONTACT_POINTS=<account>.cassandra.cosmos.azure.com
LOOMIC_CASSANDRA_PORT=10350
LOOMIC_CASSANDRA_USERNAME=<account>
LOOMIC_CASSANDRA_PASSWORD=<primary-key>
LOOMIC_CASSANDRA_KEYSPACE=loomic
LOOMIC_CASSANDRA_SSL=true
LOOMIC_CASSANDRA_CA_CERT=<PEM-encoded DigiCert CA cert, or leave empty to skip verification>

# ── Azure Blob Storage ────────────────────────────────────────
# Storage account name (not the full URL)
LOOMIC_AZURE_STORAGE_ACCOUNT=<account-name>
# Either a primary/secondary access key from the portal (base64 string)
LOOMIC_AZURE_STORAGE_KEY=<access-key>
# Container name — must exist and be set to private access
LOOMIC_AZURE_CONTAINER=loomic-uploads
# SAS token lifetime in minutes (default: 60)
LOOMIC_AZURE_SAS_TTL_MINUTES=60

# ── Logging ────────────────────────────────────────────────────
LOOMIC_LOG_LEVEL=info
LOOMIC_LOG_FILE=logs/server.log

# ── Metrics ────────────────────────────────────────────────────
LOOMIC_METRICS_PORT=9090
