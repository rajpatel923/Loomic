# ──────────────────────────────────────────────────────────────
# Loomic Server – Environment Variables Template
# Copy this file to .env and fill in your real values.
# .env is git-ignored; this file is safe to commit.
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
# libpqxx connection string used by the server
LOOMIC_PG_CONN_STRING=host=<pg-host> port=5432 dbname=<dbname> user=<user> password=<password> sslmode=require

# ── Auth ───────────────────────────────────────────────────────
LOOMIC_JWT_SECRET=<long-random-secret>

# ── Network ────────────────────────────────────────────────────
LOOMIC_BIND_ADDRESS=0.0.0.0
LOOMIC_PORT=7777
LOOMIC_HTTP_HEALTH_PORT=8080
LOOMIC_THREAD_COUNT=0

# ── TLS ────────────────────────────────────────────────────────
LOOMIC_TLS_CERT_PATH=certs/server.crt
LOOMIC_TLS_KEY_PATH=certs/server.key

# ── Redis ──────────────────────────────────────────────────────
LOOMIC_REDIS_HOST=127.0.0.1
LOOMIC_REDIS_PORT=6379

# ── ScyllaDB ───────────────────────────────────────────────────
LOOMIC_SCYLLA_HOSTS=127.0.0.1

# ── Logging ────────────────────────────────────────────────────
LOOMIC_LOG_LEVEL=info
LOOMIC_LOG_FILE=logs/server.log

# ── Metrics ────────────────────────────────────────────────────
LOOMIC_METRICS_PORT=9090
