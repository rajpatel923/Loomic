{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Message Rate (msg/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "loomic-prometheus" },
          "expr": "rate(loomic_messages_total[1m])",
          "legendFormat": "messages/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p99 Message Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "loomic-prometheus" },
          "expr": "histogram_quantile(0.99, rate(loomic_message_latency_ms_bucket[1m]))",
          "legendFormat": "p99 latency ms",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5    },
              { "color": "red",    "value": 10   }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Sessions",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "loomic-prometheus" },
          "expr": "loomic_active_sessions",
          "legendFormat": "sessions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 5000  },
              { "color": "red",    "value": 9000  }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP Error Rate (4xx/5xx per sec)",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "loomic-prometheus" },
          "expr": "rate(loomic_http_requests_total{status=~\"4..|5..\"}[1m])",
          "legendFormat": "{{method}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "tags": ["loomic", "production"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Loomic",
  "uid": "loomic-overview",
  "version": 1
}
