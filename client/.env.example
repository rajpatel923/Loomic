#
# Backend base URL used by the Next.js API proxy routes in local development.
# Copy this file to `.env.local` and point it at the Loomic backend you want
# your local Next.js dev server to talk to.
#
LOOMIC_API_BASE_URL=http://127.0.0.1:8080

#
# Optional overrides for the browser-safe TCP bridge used by /chat.
# By default the bridge derives the host from LOOMIC_API_BASE_URL, uses port
# 9000, and skips TLS certificate verification to simplify local development.
#
# LOOMIC_TCP_HOST=127.0.0.1
# LOOMIC_TCP_PORT=9000
# LOOMIC_TCP_SERVERNAME=localhost
# LOOMIC_TCP_VERIFY_TLS=false
